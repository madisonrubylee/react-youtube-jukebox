{
  "name": "react-youtube-jukebox-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "pnpm --filter @react-youtube-jukebox/docs dev",
    "dev:docs": "pnpm --filter @react-youtube-jukebox/docs dev",
    "build": "pnpm -r build",
    "build:package": "pnpm --filter react-youtube-jukebox build",
    "build:docs": "pnpm --filter @react-youtube-jukebox/docs build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter react-youtube-jukebox test",
    "publish:check": "pnpm --filter react-youtube-jukebox build && pnpm --filter react-youtube-jukebox pack:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  },
  "version": "0.0.1"
}
