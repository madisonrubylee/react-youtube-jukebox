{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "incremental": true,
    "paths": {
      "@react-youtube-jukebox/core": [
        "../../packages/react-youtube-jukebox/src/index.ts"
      ],
      "@react-youtube-jukebox/core/styles.css": [
        "../../packages/react-youtube-jukebox/src/styles/jukebox.css"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "resolveJsonModule": true,
    "jsx": "preserve"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
